{
  "manifest_version": 3,
  "name": "FlowState",
  "version": "1.0",
  "description": "Dev context switcher that saves and restores browser tab sessions.",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
